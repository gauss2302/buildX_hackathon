# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# env files
.env*
.env.development
!.env.production.example

# docker / artifacts
docker-compose.override.yml
.docker/

# certs & keys (Let's Encrypt lives in /etc/letsencrypt on the host, but never commit local ones)
*.pem
*.key
*.crt
*.csr

# debug & logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# OS noise
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# editors / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
